{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zonthor Studio",
  "version": "0.2.3",
  "identifier": "com.zonthor.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zonthor Studio",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Generate and burn subtitles into videos",
    "longDescription": "Portable subtitle generator and burner using Whisper and FFmpeg.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/ambient/*.opus",
      "assets/ir/*.wav"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mitsuhaq/subtitle-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGRThERUQ0REFBMjVENEEKUldSS1hhTGExTjdvUHliaWJWaE1mQkFsZEJrQzJsdEo1VXNLNFBhWUM2UnBSR2cyc01WeFo2c0sK"
    }
  }
}
